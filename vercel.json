{
  "buildCommand": "pnpm run typecheck && pnpm --filter @workspace/vaultchat run build",
  "outputDirectory": "artifacts/vaultchat/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "PORT": "3000",
    "BASE_PATH": "/"
  }
}
